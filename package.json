{
  "name": "web-coder",
  "private": true,
  "type": "module",
  "scripts": {
    "db:down": "docker compose -f docker-compose.postgres.yml down",
    "db:up": "docker compose -f docker-compose.postgres.yml up -d",
    "dev": "concurrently -k -n server,client -c green,blue \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "node-gyp": "^12.2.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "vite": "^8.0.0"
  }
}
